#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""ai-brain — entrypoint shim.

The real implementation lives in src/ai_brain/. This file:
- makes the script runnable from any checkout (./bin/ai-brain …),
- adds the src/ directory to sys.path so `python -m ai_brain.cli` is not required,
- delegates to ai_brain.cli.main().
"""
from __future__ import annotations

import sys
from pathlib import Path

# Ensure the package can be imported when this script runs directly,
# without requiring `pip install -e .` (we ship a thin shim for portability).
_THIS = Path(__file__).resolve()
_SRC = _THIS.parent.parent / "src"
if _SRC.is_dir() and str(_SRC) not in sys.path:
    sys.path.insert(0, str(_SRC))

from ai_brain.cli import main  # noqa: E402

if __name__ == "__main__":
    sys.exit(main())
